<xml xmlns="https://developers.google.com/blockly/xml"><variables></variables><block type="pxt-on-start" id="#!NPQIO0pB~Y5v${jtu|" x="20" y="20"><statement name="HANDLER"><block type="typescript_statement" id="y93=dQZ;`0go|g:_=[h6"><mutation xmlns="http://www.w3.org/1999/xhtml" line0="namespace anemometro {" line1="    let velocidad_kmh = 0" line2="    let velocidad_ms = 0" line3="    let tiempoEntrePulsos = 0" line4="    let tiempoAnterior = 0" line5="    let tiempoActual = 0" line6="    let diametroCm = 7" line7="    let circunferencia = Math.PI * (diametroCm / 100)" line8="    let estadoAnterior = 1" line9="    let estadoActual = 1" line10="    let pinSensor = DigitalPin.P0" line11="    let iniciado = false" line12="" line13="    /**" line14="     * Inicia el sensor para medir velocidad con un imán." line15="     * @param pin pin digital donde está conectado el sensor" line16="     * @param diametroCentimetros diámetro de la rueda o hélice en centímetros" line17="     */" line18="    //% block=&quot;iniciar sensor en pin %pin con diámetro %diametroCentimetros cm&quot;" line19="    //% diametroCentimetros.defl=7" line20="    export function iniciar(pin: DigitalPin, diametroCentimetros: number): void {" line21="        pinSensor = pin" line22="        diametroCm = diametroCentimetros" line23="" line24="        // Convierte el diámetro de cm a metros" line25="        circunferencia = Math.PI * (diametroCm / 100)" line26="" line27="        velocidad_kmh = 0" line28="        velocidad_ms = 0" line29="        tiempoAnterior = 0" line30="        estadoAnterior = 1" line31="" line32="        pins.setPull(pinSensor, PinPullMode.PullUp)" line33="" line34="        if (!iniciado) {" line35="            iniciado = true" line36="" line37="            control.inBackground(function () {" line38="                while (true) {" line39="                    estadoActual = pins.digitalReadPin(pinSensor)" line40="" line41="                    // Detecta cuando pasa el imán" line42="                    if (estadoAnterior == 1 &amp;&amp; estadoActual == 0) {" line43="                        tiempoActual = input.runningTime()" line44="" line45="                        if (tiempoAnterior &gt; 0) {" line46="                            tiempoEntrePulsos = tiempoActual - tiempoAnterior" line47="                            velocidad_ms = circunferencia / (tiempoEntrePulsos / 1000)" line48="                            velocidad_kmh = velocidad_ms * 3.6" line49="                        }" line50="" line51="                        tiempoAnterior = tiempoActual" line52="                    }" line53="" line54="                    estadoAnterior = estadoActual" line55="" line56="                    // Si no detecta vueltas por 2 segundos, velocidad = 0" line57="                    if (tiempoAnterior &gt; 0 &amp;&amp; input.runningTime() - tiempoAnterior &gt; 2000) {" line58="                        velocidad_ms = 0" line59="                        velocidad_kmh = 0" line60="                    }" line61="" line62="                    basic.pause(1)" line63="                }" line64="            })" line65="        }" line66="    }" line67="" line68="    /**" line69="     * Devuelve la velocidad en kilómetros por hora con 2 decimales." line70="     */" line71="    //% block=&quot;velocidad en km/h&quot;" line72="    export function velocidadKmH(): number {" line73="        return Math.round(velocidad_kmh * 100) / 100" line74="    }" line75="" line76="    /**" line77="     * Devuelve la velocidad en metros por segundo con 2 decimales." line78="     */" line79="    //% block=&quot;velocidad en m/s&quot;" line80="    export function velocidadMS(): number {" line81="        return Math.round(velocidad_ms * 100) / 100" line82="    }" line83="" line84="    /**" line85="     * Reinicia la medición de velocidad." line86="     */" line87="    //% block=&quot;reiniciar medición&quot;" line88="    export function reiniciar(): void {" line89="        velocidad_kmh = 0" line90="        velocidad_ms = 0" line91="        tiempoAnterior = 0" line92="    }" line93="}" numlines="94"></mutation></block></statement></block></xml>