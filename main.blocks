<xml xmlns="https://developers.google.com/blockly/xml"><variables></variables><block type="pxt-on-start" id="M3w5zTDjB3LxX-yO)L-e" x="0" y="0"><statement name="HANDLER"><block type="typescript_statement" id="pb[7|tHP0Kn`C~+HKU56"><mutation xmlns="http://www.w3.org/1999/xhtml" line0="namespace anemometro {" line1="    let velocidad_kmh = 0" line2="    let velocidad_ms = 0" line3="    let tiempoEntrePulsos = 0" line4="    let tiempoAnterior = 0" line5="    let tiempoActual = 0" line6="    let diametro = 0.07" line7="    let circunferencia = Math.PI * diametro" line8="    let estadoAnterior = 1" line9="    let estadoActual = 1" line10="    let pinSensor = DigitalPin.P0" line11="    let iniciado = false" line12="" line13="    /**" line14="     * Inicia el sensor para medir velocidad con un imán." line15="     * @param pin pin digital donde está conectado el sensor" line16="     * @param diametroMetros diámetro de la rueda o hélice en metros" line17="     */" line18="    //% block=&quot;iniciar sensor en pin %pin con diámetro %diametroMetros m&quot;" line19="    //% diametroMetros.defl=0.07" line20="    export function iniciar(pin: DigitalPin, diametroMetros: number): void {" line21="        pinSensor = pin" line22="        diametro = diametroMetros" line23="        circunferencia = Math.PI * diametro" line24="" line25="        velocidad_kmh = 0" line26="        velocidad_ms = 0" line27="        tiempoAnterior = 0" line28="        estadoAnterior = 1" line29="" line30="        pins.setPull(pinSensor, PinPullMode.PullUp)" line31="" line32="        if (!iniciado) {" line33="            iniciado = true" line34="" line35="            control.inBackground(function () {" line36="                while (true) {" line37="                    estadoActual = pins.digitalReadPin(pinSensor)" line38="" line39="                    // Detecta cuando pasa el imán" line40="                    if (estadoAnterior == 1 &amp;&amp; estadoActual == 0) {" line41="                        tiempoActual = input.runningTime()" line42="" line43="                        if (tiempoAnterior &gt; 0) {" line44="                            tiempoEntrePulsos = tiempoActual - tiempoAnterior" line45="                            velocidad_ms = circunferencia / (tiempoEntrePulsos / 1000)" line46="                            velocidad_kmh = velocidad_ms * 3.6" line47="                        }" line48="" line49="                        tiempoAnterior = tiempoActual" line50="                    }" line51="" line52="                    estadoAnterior = estadoActual" line53="" line54="                    // Si no detecta vueltas por 2 segundos, velocidad = 0" line55="                    if (tiempoAnterior &gt; 0 &amp;&amp; input.runningTime() - tiempoAnterior &gt; 2000) {" line56="                        velocidad_ms = 0" line57="                        velocidad_kmh = 0" line58="                    }" line59="" line60="                    basic.pause(1)" line61="                }" line62="            })" line63="        }" line64="    }" line65="" line66="    /**" line67="     * Devuelve la velocidad en kilómetros por hora con 2 decimales." line68="     */" line69="    //% block=&quot;velocidad en km/h&quot;" line70="    export function velocidadKmH(): number {" line71="        // Multiplica por 100, redondea al entero más cercano y divide entre 100" line72="        return Math.round(velocidad_kmh * 100) / 100" line73="    }" line74="" line75="    /**" line76="     * Devuelve la velocidad en metros por segundo con 2 decimales." line77="     */" line78="    //% block=&quot;velocidad en m/s&quot;" line79="    export function velocidadMS(): number {" line80="        // Multiplica por 100, redondea al entero más cercano y divide entre 100" line81="        return Math.round(velocidad_ms * 100) / 100" line82="    }" line83="" line84="    /**" line85="     * Reinicia la medición de velocidad." line86="     */" line87="    //% block=&quot;reiniciar medición&quot;" line88="    export function reiniciar(): void {" line89="        velocidad_kmh = 0" line90="        velocidad_ms = 0" line91="        tiempoAnterior = 0" line92="    }" line93="}" numlines="94"></mutation></block></statement></block></xml>