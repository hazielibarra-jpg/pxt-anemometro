<xml xmlns="https://developers.google.com/blockly/xml"><variables></variables><block type="pxt-on-start" id="qhAF_vw3=|$`G.lj/vqn" x="20" y="20"><statement name="HANDLER"><block type="typescript_statement" id="+?SBKGAYHCsE2q1e/Y:["><mutation xmlns="http://www.w3.org/1999/xhtml" line0="namespace anemometro {" line1="    let velocidad_kmh = 0" line2="    let velocidad_ms = 0" line3="    let tiempoEntrePulsos = 0" line4="    let tiempoAnterior = 0" line5="    let tiempoActual = 0" line6="    let diametroCm = 7" line7="    let circunferencia = Math.PI * (diametroCm / 100)" line8="    let estadoAnterior = 1" line9="    let estadoActual = 1" line10="    let pinSensor = DigitalPin.P0" line11="    let iniciado = false" line12="" line13="    /**" line14="     * Inicia el sensor para medir velocidad con un imán." line15="     * @param pin pin digital donde está conectado el sensor" line16="     * @param diametroCentimetros diámetro de la rueda o hélice en centímetros" line17="     */" line18="    //% block=&quot;iniciar sensor en pin %pin con diámetro %diametroCentimetros cm&quot;" line19="    //% diametroCentimetros.defl=7" line20="    export function iniciar(pin: DigitalPin, diametroCentimetros: number): void {" line21="        pinSensor = pin" line22="        diametroCm = diametroCentimetros" line23="" line24="        // Convierte el diámetro de cm a metros" line25="        circunferencia = Math.PI * (diametroCm / 100)" line26="" line27="        velocidad_kmh = 0" line28="        velocidad_ms = 0" line29="        tiempoAnterior = 0" line30="        estadoAnterior = 1" line31="" line32="        pins.setPull(pinSensor, PinPullMode.PullUp)" line33="" line34="        if (!iniciado) {" line35="            iniciado = true" line36="" line37="            control.inBackground(function () {" line38="                while (true) {" line39="                    estadoActual = pins.digitalReadPin(pinSensor)" line40="" line41="                    // Detecta cuando pasa el imán" line42="                    if (estadoAnterior == 1 &amp;&amp; estadoActual == 0) {" line43="                        tiempoActual = input.runningTime()" line44="" line45="                        if (tiempoAnterior &gt; 0) {" line46="                            tiempoEntrePulsos = tiempoActual - tiempoAnterior" line47="" line48="                            // Calcula la velocidad y multiplica el resultado por 10" line49="                            velocidad_ms = (circunferencia / (tiempoEntrePulsos / 1000)) * 10" line50="                            velocidad_kmh = (velocidad_ms * 3.6*100)" line51="                        }" line52="" line53="                        tiempoAnterior = tiempoActual" line54="                    }" line55="" line56="                    estadoAnterior = estadoActual" line57="" line58="                    // Si no detecta vueltas por 2 segundos, velocidad = 0" line59="                    if (tiempoAnterior &gt; 0 &amp;&amp; input.runningTime() - tiempoAnterior &gt; 2000) {" line60="                        velocidad_ms = 0" line61="                        velocidad_kmh = 0" line62="                    }" line63="" line64="                    basic.pause(1)" line65="                }" line66="            })" line67="        }" line68="    }" line69="" line70="    /**" line71="     * Devuelve la velocidad en kilómetros por hora con 2 decimales." line72="     */" line73="    //% block=&quot;velocidad en km/h corregida&quot;" line74="    export function velocidadKmH(): number {" line75="        return Math.round(velocidad_kmh * 100) / 100" line76="    }" line77="" line78="    /**" line79="     * Devuelve la velocidad en metros por segundo con 2 decimales." line80="     */" line81="    //% block=&quot;velocidad en m/s corregida&quot;" line82="    export function velocidadMS(): number {" line83="        return Math.round(velocidad_ms * 100) / 100" line84="    }" line85="" line86="    /**" line87="     * Reinicia la medición de velocidad." line88="     */" line89="    //% block=&quot;reiniciar medición&quot;" line90="    export function reiniciar(): void {" line91="        velocidad_kmh = 0" line92="        velocidad_ms = 0" line93="        tiempoAnterior = 0" line94="    }" line95="}" numlines="96"></mutation></block></statement></block></xml>